{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "task-blueprint.schema.json",
  "title": "Agent Task Blueprint",
  "description": "Schema-validated task contract for autonomous AI agent dispatch",
  "type": "object",
  "required": ["task_id", "metadata", "task", "output", "constraints"],
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^[A-Z]+-[0-9]{4}-[0-9]{3}-B[0-9]+-N[0-9]+$",
      "description": "Unique task ID: PROJECT-YEAR-SEQ-BATCH-NODE"
    },
    "metadata": {
      "type": "object",
      "required": ["project", "node", "workstream", "batch", "priority", "tier"],
      "properties": {
        "project": { "type": "string" },
        "node": { "type": "integer", "minimum": 0 },
        "workstream": { "type": "string" },
        "batch": { "type": "integer", "minimum": 1 },
        "priority": { "type": "string", "enum": ["P1", "P2", "P3", "P4"] },
        "deadline": { "type": "string", "format": "date" },
        "tier": { "type": "integer", "enum": [1, 2, 3] }
      }
    },
    "task": {
      "type": "object",
      "required": ["type", "objective", "instructions"],
      "properties": {
        "type": { "type": "string", "enum": ["EDIT", "CREATE", "REVIEW", "RESEARCH", "EXECUTE"] },
        "target_file": { "type": "string" },
        "objective": { "type": "string", "minLength": 10 },
        "instructions": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "dependencies": {
          "type": "array",
          "items": { "type": "string" }
        },
        "mcp_tools_required": {
          "type": "array",
          "items": { "type": "string", "enum": ["filesystem", "bash", "github", "knowledge", "search", "gemini-cache", "gemini-search", "gemini-deep-research", "computer_use"] }
        },
        "context_queries": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Queries to run against Gemini cache before starting task"
        },
        "gui_config": {
          "type": "object",
          "description": "Configuration for SUPERVISE mode GUI automation tasks",
          "properties": {
            "target_application": {
              "type": "string",
              "description": "Name of the legacy application (e.g., 'Dentrix', 'QuickBooks Desktop')"
            },
            "input_file": {
              "type": "string",
              "description": "Path to input data file (CSV, PDF, image)"
            },
            "record_count": {
              "type": "integer",
              "minimum": 1,
              "description": "Expected number of records to process"
            },
            "url_allowlist": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Approved URLs the SUPERVISE agent can navigate to"
            },
            "visual_success_criteria": {
              "type": "string",
              "description": "What success looks like on screen (for verification)"
            }
          }
        }
      }
    },
    "output": {
      "type": "object",
      "required": ["report_file", "status_options"],
      "properties": {
        "report_file": { "type": "string", "pattern": "^reports/.*\\.(md|json)$" },
        "status_options": {
          "type": "array",
          "items": { "type": "string", "enum": ["PASS", "FAIL", "PARTIAL", "BLOCKED"] }
        },
        "required_fields": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "constraints": {
      "type": "object",
      "properties": {
        "write_scope": { "type": "array", "items": { "type": "string" } },
        "read_scope": { "type": "array", "items": { "type": "string" } },
        "forbidden": { "type": "array", "items": { "type": "string" } },
        "requires_human_approval": { "type": "boolean", "default": false }
      }
    },
    "envelope": {
      "type": "object",
      "description": "Anti-loop task envelope for completion loop tracking (V3 integration)",
      "properties": {
        "ttl_max": {
          "type": "integer",
          "default": 10,
          "minimum": 1,
          "description": "Maximum hops before task is sent to dead-letter queue"
        },
        "hops": {
          "type": "integer",
          "default": 0,
          "minimum": 0,
          "description": "Current hop count — incremented on each retry"
        },
        "mode": {
          "type": "string",
          "enum": ["EXECUTE", "ARCHITECT", "SUPERVISE"],
          "default": "EXECUTE",
          "description": "Current prompt mode for Claude Code"
        },
        "state_hashes": {
          "type": "array",
          "items": { "type": "string" },
          "description": "SHA-256 hashes of file state before/after each hop for backflow detection"
        },
        "consecutive_failures": {
          "type": "integer",
          "default": 0,
          "minimum": 0,
          "description": "Consecutive failure count — triggers ARCHITECT mode at 3"
        },
        "consecutive_successes": {
          "type": "integer",
          "default": 0,
          "minimum": 0,
          "description": "Consecutive success count — de-escalates from ARCHITECT at 2"
        },
        "escalated": {
          "type": "boolean",
          "default": false,
          "description": "Whether task has been escalated to ARCHITECT mode"
        },
        "session_ids": {
          "type": "array",
          "items": { "type": "string" },
          "description": "All Claude Code session IDs used for this task"
        },
        "mcp_cache_key": {
          "type": "string",
          "description": "Key for brain-damage-prevention MCP cache context"
        }
      }
    }
  }
}
